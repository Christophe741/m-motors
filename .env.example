# Copy this file to .env and fill in the values
DATABASE_URL="postgresql://postgres:your_postgres_password@localhost:5432/mmotors"
JWT_SECRET="change_me_with_a_strong_secret"

# Alerting (optionnel) : URL d'un webhook Discord ou Slack.
# Si vide, l'alerting est désactivé (l'application fonctionne normalement).
ALERT_WEBHOOK_URL=""

# UploadThing : stockage des justificatifs (https://uploadthing.com).
# Récupère le token dans le dashboard de l'app UploadThing.
# Si vide, l'application fonctionne mais l'upload des justificatifs échoue.
UPLOADTHING_TOKEN=""
